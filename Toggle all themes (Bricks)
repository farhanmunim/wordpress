{"content":[{"id":"itizsh","name":"div","parent":0,"children":["onyhbt","szbxls","fdwpte","ddplzu","homhqx"],"settings":{"tag":"custom","customTag":"fieldset","_cssGlobalClasses":["gongfh"]},"label":"Toggle All Themes"},{"id":"onyhbt","name":"code","parent":"itizsh","children":[],"settings":{"javascriptCode":"// Check and set initial theme\nfunction checkAndSetInitialTheme() {\n    const themePreference = localStorage.getItem(\"themePreference\");\n\n    if (!themePreference) {\n        setSystemTheme();\n    } else if (themePreference === \"light\") {\n        setLightTheme();\n    } else if (themePreference === \"dark\") {\n        setDarkTheme();\n    } else if (themePreference === \"system\") {\n        setSystemTheme();\n    }\n}\n\n// Listen to toggle\nfunction setupThemeToggleListener() {\n    const themeToggles = document.querySelectorAll('.toggle-all-themes__input[name=\"theme\"]');\n\n    themeToggles.forEach((toggle) => {\n        toggle.addEventListener(\"change\", function() {\n            if (this.value === \"light\") {\n                setLightTheme();\n            } else if (this.value === \"dark\") {\n                setDarkTheme();\n            } else if (this.value === \"system\") {\n                setSystemTheme();\n            }\n        });\n    });\n}\n\n// Listen to system preference\nfunction setupSystemThemeChangeListener() {\n    const mediaQueryList = window.matchMedia(\"(prefers-color-scheme: dark)\");\n    mediaQueryList.addEventListener(\"change\", updateSystemTheme);\n    updateSystemTheme();\n}\n\n// Basic functions\nfunction setSystemTheme() {\n    const prefersDarkScheme = window.matchMedia(\"(prefers-color-scheme: dark)\").matches;\n    \n    resetThemeToggles();\n    document.querySelector('.toggle-all-themes__input[name=\"theme\"][value=\"system\"]').checked = true;\n    document.documentElement.setAttribute(\"data-theme\", prefersDarkScheme ? \"dark\" : \"light\");\n    localStorage.setItem(\"themePreference\", \"system\");\n}\n\nfunction setLightTheme() {\n    resetThemeToggles();\n    document.querySelector('.toggle-all-themes__input[name=\"theme\"][value=\"light\"]').checked = true;\n    document.documentElement.setAttribute(\"data-theme\", \"light\");\n    localStorage.setItem(\"themePreference\", \"light\");\n}\n\nfunction setDarkTheme() {\n    resetThemeToggles();\n    document.querySelector('.toggle-all-themes__input[name=\"theme\"][value=\"dark\"]').checked = true;\n    document.documentElement.setAttribute(\"data-theme\", \"dark\");\n    localStorage.setItem(\"themePreference\", \"dark\");\n}\n\nfunction updateSystemTheme() {\n    const prefersDarkScheme = window.matchMedia(\"(prefers-color-scheme: dark)\").matches;\n    const storedPreference = localStorage.getItem(\"themePreference\");\n    const currentTheme = document.documentElement.getAttribute(\"data-theme\");\n\n    if (storedPreference === \"system\") {\n        if ((prefersDarkScheme && currentTheme !== \"dark\") || (!prefersDarkScheme && currentTheme !== \"light\")) {\n            setSystemTheme();\n        }\n    }\n}\n\nfunction resetThemeToggles() {\n    document.querySelectorAll('.toggle-all-themes__input[name=\"theme\"]').forEach((toggle) => {\n        toggle.checked = false;\n    });\n}\n\n// On page load\nwindow.addEventListener(\"DOMContentLoaded\", () => {\n    checkAndSetInitialTheme();\n    setupThemeToggleListener();\n    setupSystemThemeChangeListener();\n});\n","executeCode":true,"parseDynamicData":true,"supressPhpErrors":true,"noRoot":true},"label":"Javascript"},{"id":"szbxls","name":"text-basic","parent":"itizsh","children":[],"settings":{"text":"Theme toggle","tag":"custom","customTag":"legend","_cssGlobalClasses":["cspspv"]},"label":"Legend"},{"id":"fdwpte","name":"div","parent":"itizsh","children":["crbjbl"],"settings":{"tag":"custom","customTag":"label","_cssGlobalClasses":["rbnwdy"]},"label":"Label"},{"id":"crbjbl","name":"div","parent":"fdwpte","children":["qevqnl"],"settings":{"tag":"custom","cu