/////////// Function to send expiring documents email
function send_expiring_documents_email() {
    // Get email address from ACF options page
    $property_management_email = get_field('property_management_email', 'option');

    // Array of custom fields to check for expiry
    $date_fields = array(
        'gas_certificate_expiry',
        'ast_expiry',
        'deposit_protection_certificate_expiry',
        'epc_expiry',
        'eicr_expiry',
        'local_authority_license_expiry'
    );

    $expiring_properties = array();

    // Fetch all posts of custom post type 'property'
    $args = array(
        'post_type' => 'property',
        'posts_per_page' => -1, // -1 to fetch all posts
    );

    $properties_query = new WP_Query($args);

    if ($properties_query->have_posts()) :
        while ($properties_query->have_posts()) :
            $properties_query->the_post();

            // Initialize an array to store expiring fields for the current post
            $expiring_fields = array();

            // Check each date field for expiry
            foreach ($date_fields as $field) {
                $expiry_date = get_field($field); // Retrieve the custom field value
                if ($expiry_date) {
                    // Parse date in d/m/Y format
                    $expiry_date_formatted = DateTime::createFromFormat('d/m/Y', $expiry_date);
                    if ($expiry_date_formatted) {
                        $current_date = new DateTime(); // Get the current date

                        // Calculate the difference in days between the current date and the expiry date
                        $diff_in_days = $current_date->diff($expiry_date_formatted)->days;

                        // Check if the expiry date is less than 30 days from now
                        if ($diff_in_days > 0 && $diff_in_days <= 30) {
                            // Add the expiring field to the current post's list
                            $expiring_fields[] = array(
                                'field' => ucfirst(str_replace('_', ' ', $field)),
                                'expiry_date' => $expiry_date
                            );
                        }
                    }
                }
            }

            // If there are expiring fields for this post, add them to the expiring properties array
            if (!empty($expiring_fields)) {
                $expiring_properties[] = array(
                    'title' => get_the_title(),
                    'expiring_fields' => $expiring_fields
                );
            }

        endwhile;
        wp_reset_postdata(); // Reset post data to avoid conflicts

        // If there are expiring properties, send an email
        if (!empty($expiring_properties)) {
            $to = $property_management_email; // Use dynamic email address
            $subject = 'Expiring Documents Notification';
            $headers = array('Content-Type: text/html; charset=UTF-8');

            $message = '<h1>Expiring Documents</h1>';
            foreach ($expiring_properties as $property) {
                $message .= '<h2>' . $property['title'] . '</h2>';
                $message .= '<ul>';
                foreach ($property['expiring_fields'] as $field) {
                    $message .= '<li>' . $field['field'] . ': ' . $field['expiry_date'] . ' (expiring soon)</li>';
                }
                $message .= '</ul>';
            }

            // Send the email
            if (wp_mail($to, $subject, $message, $headers)) {
                echo 'Email sent successfully.';
            } else {
                echo 'Failed to send email.';
            }
        } else {
            echo 'No documents expiring soon.';
        }
    else :
        echo 'No properties found.';
    endif;
}

