/////////// Function to send expired documents email
function send_expired_documents_email() {
    // Get email address from ACF options page
    $property_management_email = get_field('property_management_email', 'option');

    // Array of custom fields to check for expiry
    $date_fields = array(
        'gas_certificate_expiry',
        'ast_expiry',
        'deposit_protection_certificate_expiry',
        'epc_expiry',
        'eicr_expiry',
        'local_authority_license_expiry'
    );

    $expired_properties = array();

    // Fetch all posts of custom post type 'property'
    $args = array(
        'post_type' => 'property',
        'posts_per_page' => -1, // -1 to fetch all posts
    );

    $properties_query = new WP_Query($args);

    if ($properties_query->have_posts()) :
        while ($properties_query->have_posts()) :
            $properties_query->the_post();

            // Initialize an array to store expired fields for the current post
            $expired_fields = array();

            // Check each date field for expiry
            foreach ($date_fields as $field) {
                $expiry_date = get_field($field); // Retrieve the custom field value
                if ($expiry_date) {
                    // Parse date in d/m/Y format
                    $expiry_date_formatted = DateTime::createFromFormat('d/m/Y', $expiry_date);
                    if ($expiry_date_formatted) {
                        $current_date = new DateTime(); // Get the current date

                        // Compare the expiry date with the current date
                        if ($expiry_date_formatted < $current_date) {
                            // Add the expired field to the current post's list
                            $expired_fields[] = ucfirst(str_replace('_', ' ', $field)) . ': ' . $expiry_date;
                        }
                    }
                }
            }

            // If there are expired fields for this post, add them to the expired properties array
            if (!empty($expired_fields)) {
                $expired_properties[] = array(
                    'title' => get_the_title(),
                    'expired_fields' => $expired_fields
                );
            }

        endwhile;
        wp_reset_postdata(); // Reset post data to avoid conflicts

        // If there are expired properties, send an email
        if (!empty($expired_properties)) {
            $to = $property_management_email; // Use dynamic email address
            $subject = 'Expired Documents Notification';
            $headers = array('Content-Type: text/html; charset=UTF-8');

            $message = '<h1>Expired Documents</h1>';
            foreach ($expired_properties as $property) {
                $message .= '<h2>' . $property['title'] . '</h2>';
                $message .= '<ul>';
                foreach ($property['expired_fields'] as $field) {
                    $message .= '<li>' . $field . ' (expired)</li>';
                }
                $message .= '</ul>';
            }

            // Send the email
            if (wp_mail($to, $subject, $message, $headers)) {
                echo 'Email sent successfully.';
            } else {
                echo 'Failed to send email.';
            }
        } else {
            echo 'No documents expired.';
        }
    else :
        echo 'No properties found.';
    endif;
}

